# Скопируй в .env и подставь свои значения. .env в git НЕ коммитить.
# 1) Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA_your_bot_token_here
# 2) Твой chat_id: напиши боту сообщение, открой
#    https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьми result[].message.chat.id
TELEGRAM_CHAT_ID=000000000
